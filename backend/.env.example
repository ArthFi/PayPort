# ═══════════════════════════════════════════════
# HP2 INTEGRATION MODES
# ═══════════════════════════════════════════════
#
# MODE 1 — Full mock (no external server needed)
#   HP2_MOCK=true
#   (all other HP2 vars ignored)
#
# MODE 2 — Local sim server (validates real auth, fires real webhooks)
#   HP2_MOCK=false
#   HP2_BASE_URL=http://localhost:3002
#   HP2_APP_KEY=sim_key_2026
#   HP2_APP_SECRET=sim_secret_2026
#   HP2_WEBHOOK_URL=http://localhost:3001/api/webhook
#   (run: node sim/hp2-sim.js in a separate terminal)
#
# MODE 3 — Real HP2 (production/hackathon)
#   HP2_MOCK=false
#   HP2_BASE_URL=https://api.hp2.hashkey.com
#   HP2_APP_KEY=<from caas@hashkey.com>
#   HP2_APP_SECRET=<from caas@hashkey.com>
#   HP2_WEBHOOK_URL=https://your-deployed-backend.com/api/webhook
#   (stop running sim server)
# ═══════════════════════════════════════════════

HP2_MOCK=false
HP2_BASE_URL=http://localhost:3002
HP2_APP_KEY=sim_key_2026
HP2_APP_SECRET=sim_secret_2026
HP2_WEBHOOK_URL=http://localhost:3001/api/webhook
